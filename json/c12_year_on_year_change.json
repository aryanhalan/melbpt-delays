{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Horizontal bar chart showing year-on-year change in punctuality (April 2025 vs April 2026) for each mode. Negative = worse, positive = better. V/Line fell 4.7pp, Metro Bus improved 0.9pp.",
  "width": 380,
  "height": 120,
  "data": {
    "values": [
      {
        "mode": "V/Line Train",
        "change": -4.7
      },
      {
        "mode": "Metro Train",
        "change": -1.0
      },
      {
        "mode": "Metro Tram",
        "change": 0.4
      },
      {
        "mode": "Metro Bus",
        "change": 0.9
      }
    ]
  },
  "mark": {
    "type": "bar",
    "height": 22
  },
  "encoding": {
    "y": {
      "field": "mode",
      "type": "nominal",
      "sort": {
        "field": "change",
        "order": "ascending"
      },
      "axis": {
        "title": null,
        "labelFontSize": 11
      }
    },
    "x": {
      "field": "change",
      "type": "quantitative",
      "axis": {
        "title": "Change in on-time rate (percentage points)",
        "format": "+.1f"
      }
    },
    "color": {
      "field": "mode",
      "type": "nominal",
      "scale": {
        "domain": [
          "Metro Train",
          "Metro Tram",
          "V/Line Train",
          "Metro Bus"
        ],
        "range": [
          "#2563eb",
          "#16a34a",
          "#7c3aed",
          "#ea580c"
        ]
      },
      "legend": null
    },
    "tooltip": [
      {
        "field": "mode",
        "title": "Mode"
      },
      {
        "field": "change",
        "title": "Year-on-year change (pp)",
        "format": "+.2f"
      }
    ]
  }
}