  "params": [
    {
      "name": "sel",
      "select": { "type": "point", "fields": ["mode"], "on": "click" },
      "bind": "legend"
    }
  ],
  "mark": {
    "type": "line",
    "point": { "filled": true, "size": 45 },
    "strokeWidth": 2.5,
    "interpolate": "monotone"
  },
  "encoding": {
    "x": {
      "field": "month", "type": "ordinal",
      "sort": ["May-25","Jun-25","Jul-25","Aug-25","Sep-25","Oct-25","Nov-25","Dec-25","Jan-26","Feb-26","Mar-26","Apr-26"],
      "axis": { "title": null, "labelAngle": -30 }
    },
    "y": {
      "field": "pct", "type": "quantitative",
      "scale": { "domain": [78, 97] },
      "axis": { "title": "On-time (%)", "tickCount": 5 }
    },
    "color": {
      "field": "mode", "type": "nominal",
      "scale": {
        "domain": ["Metro Train", "Metro Tram", "V/Line Train", "Metro Bus"],
        "range":  ["#2563eb",    "#16a34a",    "#7c3aed",     "#ea580c"]
      },
      "legend": { "title": "Mode — click to highlight" }
    },
    "opacity": {
      "condition": { "param": "sel", "value": 1 },
      "value": 0.15
    },
    "tooltip": [
      { "field": "month", "title": "Month" },
      { "field": "mode",  "title": "Mode" },
      { "field": "pct",   "title": "Punctuality (%)", "format": ".1f" }
    ]
  }
}
